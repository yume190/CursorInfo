{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VSCode Lite",
  "version": "0.1.0",
  "identifier": "com.yume.vscodelite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run prepare:binaries",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VSCode Lite",
        "width": 1600,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "bin/cursor-info",
      "bin/demangle"
    ]
  }
}
